# Create .env from this file, then replace both placeholders with strong values.
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# VPS -> local PC, ideally a Tailscale IP such as http://100.x.y.z:11434
# Do not use a public Ollama URL.
OLLAMA_BASE_URL=http://100.64.0.10:11434
OLLAMA_MAX_CONCURRENT_GENERATIONS=1
OLLAMA_QUEUE_WAIT_SECONDS=15
