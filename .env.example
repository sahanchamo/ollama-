# Create .env from this file, then replace both placeholders with strong values.
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-password-of-at-least-12-characters
MAX_CONCURRENT_GENERATIONS=1
GENERATION_QUEUE_SECONDS=90
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
# Free self-hosted web research (SearXNG is started by docker compose).
WEB_SEARCH_ENABLED=true
SEARXNG_SECRET=replace-with-a-long-random-searxng-secret
# For a PC-hosted Ollama over Tailscale Serve, use its private Serve hostname.
# OLLAMA_BASE_URL=http://your-pc.tailnet.ts.net:11434
