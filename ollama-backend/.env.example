APP_NAME=Ollama Gateway
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql+asyncpg://ollama:change-this-postgres-password@postgres:5432/ollama_gateway
REDIS_URL=redis://redis:6379/0
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TIMEOUT_SECONDS=180
ALLOWED_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_PER_MINUTE=30
MAX_PROMPT_CHARS=20000
LOG_LEVEL=INFO
RAG_ENABLED=true
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_DIMENSIONS=768
RAG_TOP_K=4
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_UPLOAD_BYTES=10485760
# Set this to the email that should be promoted to administrator on startup.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# Creates this admin only if the email does not already exist. Never stored as plain text.
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-password-of-at-least-12-characters
